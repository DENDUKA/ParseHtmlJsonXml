{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "WordCounterSettings": {
    "Delimiters": [
      " ",
      ",",
      ".",
      "!",
      "?",
      "\"",
      ";",
      ":",
      "[",
      "]",
      "(",
      ")",
      "\n",
      "\r",
      "\t"
    ],
    "MaxConcurrency": 10,
    "TimeoutSeconds": 15
  }
}
